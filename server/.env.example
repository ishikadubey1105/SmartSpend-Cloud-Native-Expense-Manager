# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smartspend?retryWrites=true&w=majority
MONGODB_URI_TEST=mongodb://localhost:27017/smartspend_test

# Firebase Admin SDK (download from Firebase Console → Project Settings → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Google Gemini AI (get from https://aistudio.google.com/app/apikey)
# Required to enable AI Insights and auto-categorize features
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# Frontend URL for CORS (update for production)
CLIENT_URL=http://localhost:5173

# Logging Level (error | warn | info | http | debug)
LOG_LEVEL=info
